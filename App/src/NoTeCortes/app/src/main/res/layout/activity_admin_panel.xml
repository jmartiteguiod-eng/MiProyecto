<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#0D47A1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/logo_notecortes"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="ADMINISTRACIÓN"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="-20dp"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/btnGestionServicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#0D47A1"
            android:text="Gestionar Servicios"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnPromociones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#0D47A1"
            android:text="Enviar Promociones"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnCerrarAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:backgroundTint="#D32F2F"
            android:text="Cerrar sesión"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>