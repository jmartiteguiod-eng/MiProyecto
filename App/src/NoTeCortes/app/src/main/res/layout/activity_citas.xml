<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- Header Azul -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#0D47A1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/logo_notecortes"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="MIS CITAS"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Contenedor de la Lista (Tarjeta Blanca) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="-30dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Selecciona una cita para gestionar:"
            android:textColor="#757575"
            android:textSize="14sp" />

        <ListView
            android:id="@+id/listViewCitas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#EEEEEE"
            android:dividerHeight="1dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:choiceMode="singleChoice" />
    </LinearLayout>

    <!-- Botón de Acción -->
    <Button
        android:id="@+id/btnCancelarCita"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:backgroundTint="#D32F2F"
        android:text="CANCELAR CITA SELECCIONADA"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:elevation="2dp" />

</LinearLayout>